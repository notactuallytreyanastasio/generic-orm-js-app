<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle : 'TodoApp' %></title>
  <link rel="stylesheet" href="/retro.css">
  <style>
    .list-row {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 6px 8px;
      border-bottom: 1px solid #e0e0e0;
      cursor: default;
    }
    .list-row:last-child {
      border-bottom: none;
    }
    .list-row:hover {
      background: var(--win95-selection);
      color: var(--win95-selection-text);
    }
    .list-row a {
      flex: 1;
      text-decoration: none;
      color: inherit;
      font-size: 15px;
    }
    .list-row .count-badge {
      font-size: 13px;
      color: var(--win95-btn-shadow);
      min-width: 50px;
      text-align: right;
    }
    .list-row:hover .count-badge {
      color: #aaaacc;
    }
    .empty-message {
      padding: 20px;
      text-align: center;
      color: var(--win95-btn-shadow);
      font-size: 15px;
    }
    .edit-form {
      display: none;
      flex: 1;
    }
    .edit-form.active {
      display: flex;
      gap: 4px;
      align-items: center;
    }
    .edit-form .win95-input {
      flex: 1;
      padding: 1px 4px;
      font-size: 14px;
    }
    .edit-form .win95-btn {
      min-width: auto;
      padding: 1px 8px;
      font-size: 12px;
    }
    .todo-text-display.hidden {
      display: none;
    }
    .nav-bar {
      display: flex;
      gap: 4px;
      padding: 4px;
      flex-wrap: wrap;
    }
    .nav-bar a {
      text-decoration: none;
    }
    .priority-badge {
      display: inline-block;
      padding: 1px 6px;
      font-size: 12px;
      border: 1px solid var(--win95-btn-shadow);
      background: var(--win95-field-bg);
      margin-left: 4px;
    }
    .priority-badge.p5 { background: #ff6666; color: #fff; }
    .priority-badge.p4 { background: #ff9933; color: #fff; }
    .priority-badge.p3 { background: #ffcc00; }
    .priority-badge.p2 { background: #99cc66; }
    .priority-badge.p1 { background: #66aacc; color: #fff; }
    .tag-badge {
      display: inline-block;
      padding: 1px 4px;
      font-size: 11px;
      border: 1px solid #999;
      background: #e8e8ff;
      margin-left: 2px;
    }
    .due-date {
      font-size: 12px;
      color: var(--win95-btn-shadow);
      margin-left: 4px;
    }
    .due-date.overdue {
      color: #cc0000;
      font-weight: bold;
    }
    table.stats-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 14px;
    }
    table.stats-table th, table.stats-table td {
      border: 1px solid var(--win95-btn-shadow);
      padding: 4px 8px;
      text-align: left;
    }
    table.stats-table th {
      background: var(--win95-btn-face);
    }
    .sql-display {
      background: #1a1a2e;
      color: #00ff00;
      font-family: 'Courier New', monospace;
      font-size: 12px;
      padding: 8px;
      margin: 4px 0;
      white-space: pre-wrap;
      word-break: break-all;
      border: 2px inset var(--win95-btn-shadow);
    }
    .section-header {
      background: var(--win95-btn-face);
      padding: 4px 8px;
      border-bottom: 1px solid var(--win95-btn-shadow);
      font-weight: bold;
      font-size: 14px;
    }
    .error-msg {
      color: #cc0000;
      font-size: 13px;
      padding: 2px 0;
    }
    .success-msg {
      color: #006600;
      font-size: 13px;
      padding: 2px 0;
    }
    .pagination {
      display: flex;
      gap: 4px;
      padding: 4px;
      align-items: center;
      justify-content: center;
    }
  </style>
</head>
<body>
  <!-- Mac System 6 Menu Bar -->
  <div class="mac-menubar">
    <span class="apple-logo">&#63743;</span>
    <a href="/" class="menu-item app-name" style="text-decoration:none;color:inherit">TodoApp</a>
    <a href="/stats" class="menu-item" style="text-decoration:none;color:inherit">Stats</a>
    <a href="/search" class="menu-item" style="text-decoration:none;color:inherit">Search</a>
    <a href="/overdue" class="menu-item" style="text-decoration:none;color:inherit">Overdue</a>
    <a href="/reports/combined" class="menu-item" style="text-decoration:none;color:inherit">Reports</a>
    <a href="/joins-demo" class="menu-item" style="text-decoration:none;color:inherit">Joins</a>
    <a href="/validation-demo" class="menu-item" style="text-decoration:none;color:inherit">Validate</a>
  </div>

  <!-- Desktop Area -->
  <div class="desktop">
